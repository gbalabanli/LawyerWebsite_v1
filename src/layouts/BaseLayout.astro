---
import { siteConfig } from '../config/site';
import HelpDeskPopup from '../components/HelpDeskPopup.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import { withBase } from '../utils/routing';
import { t, type Lang } from '../i18n/ui';
import { translations } from '../i18n/translations';
import { getAlternatePath } from '../i18n/utils';
import '../styles/base.css';
import '../templates/classic-legal/tokens.css';
import '../templates/classic-legal/layout.css';
import '../templates/modern-minimal/tokens.css';
import '../templates/modern-minimal/layout.css';

interface Props {
	title?: string;
	description?: string;
	pathname?: string;
	ogType?: 'website' | 'article';
	lang?: Lang;
	article?: {
		publishedTime?: string;
		modifiedTime?: string;
		tags?: string[];
	};
}

const {
	title = siteConfig.seo.defaultTitle.tr,
	description = siteConfig.seo.defaultDescription.tr,
	pathname = Astro.url.pathname,
	ogType = 'website',
	lang = 'tr',
	article,
} = Astro.props;
const basePath = import.meta.env.BASE_URL || '/';
const pathnameWithoutBase =
	basePath !== '/' && pathname.startsWith(basePath)
		? pathname.slice(basePath.length - 1)
		: pathname;

const canonicalUrl = new URL(pathname, siteConfig.seo.siteUrl).toString();
const altLang: Lang = lang === 'tr' ? 'en' : 'tr';
const altPathRaw = getAlternatePath(pathnameWithoutBase, altLang);
const alternateUrl = new URL(
	basePath !== '/' ? `${basePath}${altPathRaw}`.replace(/\/+/g, '/') : altPathRaw,
	siteConfig.seo.siteUrl,
).toString();

const nav = [
	{ href: lang === 'tr' ? '/' : '/en/', key: 'home' as const },
	{ href: lang === 'tr' ? '/hakkimda' : '/en/about', key: 'about' as const },
	{ href: lang === 'tr' ? '/iletisim' : '/en/contact', key: 'contact' as const },
	{ href: lang === 'tr' ? '/blog' : '/en/blog', key: 'blog' as const },
];
const faviconSvg = withBase('/favicon.svg');
const faviconIco = withBase('/favicon.ico');
const htmlLang = lang === 'tr' ? 'tr' : 'en';
const ogLocale = translations[lang].seo.locale;
const rightsText = translations[lang].footer.rights;

const legalServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'LegalService',
	name: siteConfig.brand.name,
	description: siteConfig.seo.defaultDescription[lang],
	url: siteConfig.seo.siteUrl,
	email: siteConfig.contact.email,
	telephone: siteConfig.contact.phoneDisplay,
	address: {
		'@type': 'PostalAddress',
		addressLocality: siteConfig.contact.address,
	},
	areaServed: 'Turkey',
};
---

<!doctype html>
<html lang={htmlLang} data-template={siteConfig.template}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang={lang === 'tr' ? 'tr' : 'en'} href={canonicalUrl} />
		<link rel="alternate" hreflang={altLang} href={alternateUrl} />
		<meta property="og:site_name" content={siteConfig.brand.name} />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content={ogLocale} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
		{article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
		{
			article?.tags?.map((tag) => (
				<meta property="article:tag" content={tag} />
			))
		}
		<link rel="icon" type="image/svg+xml" href={faviconSvg} />
		<link rel="icon" href={faviconIco} />
		<script type="application/ld+json" set:html={JSON.stringify(legalServiceSchema)} />
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<div class="container header-row">
					<a class="brand" href={withBase(lang === 'tr' ? '/' : '/en/')}>{siteConfig.brand.name}</a>
					<nav class="nav" aria-label="Primary">
						{
							nav.map((item) => (
								<a href={withBase(item.href)} aria-current={pathnameWithoutBase === item.href ? 'page' : undefined}>
									{t(lang, `nav.${item.key}`)}
								</a>
							))
						}
					</nav>
					<LangSwitcher lang={lang} pathname={pathnameWithoutBase} />
				</div>
			</header>
			<main class="main-content">
				<div class="container">
					<slot />
				</div>
			</main>
			<footer class="site-footer">
				<div class="container footer-grid">
					<div class="footer-col footer-brand">
						<p class="footer-heading">{siteConfig.brand.name}</p>
						<p>{siteConfig.contact.address}</p>
						<p>{siteConfig.contact.phoneDisplay}</p>
						<p>{siteConfig.contact.email}</p>
						<p class="footer-version">{siteConfig.version}</p>
					</div>
					<div class="footer-col">
						<p class="footer-heading">{t(lang, 'footer.quickLinks')}</p>
						<nav aria-label="Footer">
							{
								nav.map((item) => (
									<a href={withBase(item.href)}>{t(lang, `nav.${item.key}`)}</a>
								))
							}
						</nav>
					</div>
					<div class="footer-col">
						<p class="footer-heading">{t(lang, 'footer.practiceAreas')}</p>
						<a href={withBase(lang === 'tr' ? '/blog' : '/en/blog')}>{t(lang, 'nav.blog')}</a>
					</div>
					<div class="footer-col">
						<p class="footer-heading">Kurumsal</p>
						<a href="https://www.istanbulbarosu.org.tr/" target="_blank" rel="noopener noreferrer">{t(lang, 'footer.barAssociation')}</a>
						<a href="https://www.barobirlik.org.tr/" target="_blank" rel="noopener noreferrer">{t(lang, 'footer.barUnion')}</a>
						<a href="https://www.adalet.gov.tr/" target="_blank" rel="noopener noreferrer">T.C. Adalet Bakanlığı</a>
						<a href="https://www.istanbulbarosu.org.tr/kategori/adli-yardim" target="_blank" rel="noopener noreferrer">{t(lang, 'footer.legalAid')}</a>
					</div>
				</div>
				<div class="container footer-bottom">
					<p>&copy; {new Date().getFullYear()} {siteConfig.brand.name} — {rightsText}</p>
				</div>
			</footer>
		</div>
		<HelpDeskPopup lang={lang} />
	</body>
</html>
