---
import { helpDeskTriggerHref, siteConfig } from '../config/site';
import HelpDeskPopup from '../components/HelpDeskPopup.astro';
import Icon from '../components/Icon.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import { withBase } from '../utils/routing';
import { t, type Lang } from '../i18n/ui';
import { translations } from '../i18n/translations';
import { getAlternatePath } from '../i18n/utils';
import { serviceAreas } from '../config/services';
import '../styles/base.css';

const activeTemplate = siteConfig.template;
if (activeTemplate === 'classic-legal') {
	await import('../templates/classic-legal/tokens.css');
	await import('../templates/classic-legal/layout.css');
} else {
	await import('../templates/modern-minimal/tokens.css');
	await import('../templates/modern-minimal/layout.css');
}

interface Props {
	title?: string;
	description?: string;
	pathname?: string;
	ogType?: 'website' | 'article';
	lang?: Lang;
	ogImage?: string;
	robots?: string;
	lastModified?: string;
	article?: {
		publishedTime?: string;
		modifiedTime?: string;
		tags?: string[];
	};
}

const {
	title = siteConfig.seo.defaultTitle.tr,
	description = siteConfig.seo.defaultDescription.tr,
	pathname = Astro.url.pathname,
	ogType = 'website',
	lang = 'tr',
	ogImage,
	robots = 'index, follow',
	lastModified,
	article,
} = Astro.props;
const basePath = import.meta.env.BASE_URL || '/';
const pathnameWithoutBase =
	basePath !== '/' && pathname.startsWith(basePath)
		? pathname.slice(basePath.length - 1)
		: pathname;

const canonicalUrl = new URL(pathname, siteConfig.seo.siteUrl).toString();
const xdefaultPath = lang === 'tr' ? pathname : getAlternatePath(pathnameWithoutBase, 'tr');
const xdefaultUrl = new URL(
	basePath !== '/' ? `${basePath}${xdefaultPath}`.replace(/\/+/g, '/') : xdefaultPath,
	siteConfig.seo.siteUrl,
).toString();
const altLang: Lang = lang === 'tr' ? 'en' : 'tr';
const altPathRaw = getAlternatePath(pathnameWithoutBase, altLang);
const alternateUrl = new URL(
	basePath !== '/' ? `${basePath}${altPathRaw}`.replace(/\/+/g, '/') : altPathRaw,
	siteConfig.seo.siteUrl,
).toString();

const nav = [
	{ href: lang === 'tr' ? '/' : '/en/', key: 'home' as const },
	{ href: lang === 'tr' ? '/hakkimda' : '/en/about', key: 'about' as const },
	{ href: lang === 'tr' ? '/hizmetler' : '/en/services', key: 'services' as const },
	{ href: lang === 'tr' ? '/iletisim' : '/en/contact', key: 'contact' as const },
	{ href: lang === 'tr' ? '/blog' : '/en/blog', key: 'blog' as const },
];
const servicesBase = lang === 'tr' ? '/hizmetler' : '/en/services';
const ogImageRaw = ogImage || siteConfig.seo.ogImage;
const ogImageUrl = ogImageRaw?.startsWith('http') ? ogImageRaw : new URL(withBase(ogImageRaw), siteConfig.seo.siteUrl).toString();
const faviconSvg = withBase('/favicon.svg');
const faviconIco = withBase('/favicon.ico');
const htmlLang = lang === 'tr' ? 'tr' : 'en';
const ogLocale = translations[lang].seo.locale;
const rightsText = translations[lang].footer.rights;

const ga4Id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID as string | undefined;

const legalServiceSchema = {
	'@context': 'https://schema.org',
	'@type': 'LegalService',
	name: siteConfig.brand.name,
	description: siteConfig.seo.defaultDescription[lang],
	url: siteConfig.seo.siteUrl,
	email: siteConfig.contact.email,
	telephone: siteConfig.contact.phoneDisplay,
	address: {
		'@type': 'PostalAddress',
		addressLocality: siteConfig.contact.address,
	},
	areaServed: 'Turkey',
};
---

<!doctype html>
<html lang={htmlLang} data-template={siteConfig.template}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		{lastModified && <meta name="dateModified" content={lastModified} />}
		<link rel="canonical" href={canonicalUrl} />
		<link rel="alternate" hreflang={lang === 'tr' ? 'tr' : 'en'} href={canonicalUrl} />
		<link rel="alternate" hreflang={altLang} href={alternateUrl} />
		<link rel="alternate" hreflang="x-default" href={xdefaultUrl} />
		<meta property="og:site_name" content={siteConfig.brand.name} />
		<meta property="og:type" content={ogType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:image" content={ogImageUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		{article?.publishedTime && <meta property="article:published_time" content={article.publishedTime} />}
		{article?.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
		{
			article?.tags?.map((tag) => (
				<meta property="article:tag" content={tag} />
			))
		}
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@400;700&family=Source+Serif+4:wght@400;600&display=swap" rel="stylesheet" />
		<link rel="icon" type="image/svg+xml" href={faviconSvg} />
		<link rel="icon" href={faviconIco} />
		<link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
		{
			ga4Id && (
				<>
					<script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
					<script set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${ga4Id}');`} />
				</>
			)
		}
		<script type="application/ld+json" set:html={JSON.stringify(legalServiceSchema)} />
	</head>
	<body>
		<div class="site-shell">
			<header class="site-header">
				<div class="container header-row">
					<a class="brand" href={withBase(lang === 'tr' ? '/' : '/en/')}>{siteConfig.brand.name}</a>
					<nav class="nav" aria-label="Primary">
						{
							nav.map((item) =>
								item.key === 'services' ? (
									<div class="nav-dropdown">
										<a href={withBase(item.href)} aria-current={pathnameWithoutBase.startsWith('/hizmetler') || pathnameWithoutBase.startsWith('/en/services') ? 'page' : undefined}>
											{t(lang, `nav.${item.key}`)}
										</a>
										<div class="dropdown-menu">
											{
												serviceAreas.map((area) => (
													<a href={withBase(`${servicesBase}/${area.slug}`)}>{area.title}</a>
												))
											}
										</div>
									</div>
								) : (
									<a href={withBase(item.href)} aria-current={pathnameWithoutBase === item.href ? 'page' : undefined}>
										{t(lang, `nav.${item.key}`)}
									</a>
								),
							)
						}
					</nav>
					<LangSwitcher lang={lang} pathname={pathnameWithoutBase} />
				</div>
			</header>
			<main class="main-content">
				<div class="container">
					<Breadcrumb pathname={pathnameWithoutBase} lang={lang} />
					<slot />
				</div>
			</main>
			<footer class="site-footer">
				<div class="container footer-grid">
					<div class="footer-col footer-brand">
						<p class="footer-heading">{siteConfig.brand.name}</p>
						<span class="footer-contact-row"><Icon name="map-pin" size={14} />{siteConfig.contact.address}</span>
						<span class="footer-contact-row"><Icon name="mail" size={14} />{siteConfig.contact.email}</span>
						<a class="btn btn-primary" href={helpDeskTriggerHref}><Icon name="message-circle" size={16} />{t(lang, 'footer.liveSupport')}</a>
						<p class="footer-version">{siteConfig.version}</p>
					</div>
					<div class="footer-col">
						<p class="footer-heading">{t(lang, 'footer.quickLinks')}</p>
						<nav aria-label="Footer">
							{
								nav.map((item) => (
									<a href={withBase(item.href)}>{t(lang, `nav.${item.key}`)}</a>
								))
							}
						</nav>
					</div>
					<div class="footer-col">
						<p class="footer-heading">{t(lang, 'footer.practiceAreas')}</p>
						{
							serviceAreas.map((area) => (
								<a href={withBase(`${servicesBase}/${area.slug}`)}>{area.title}</a>
							))
						}
					</div>
					<div class="footer-col">
						<p class="footer-heading">{t(lang, 'footer.institutions')}</p>
						<a href="https://www.istanbulbarosu.org.tr/" target="_blank" rel="noopener noreferrer"><Icon name="external-link" size={12} />{t(lang, 'footer.barAssociation')}</a>
						<a href="https://www.barobirlik.org.tr/" target="_blank" rel="noopener noreferrer"><Icon name="external-link" size={12} />{t(lang, 'footer.barUnion')}</a>
						<a href="https://www.istanbulbarosu.org.tr/ucrettarifeleri" target="_blank" rel="noopener noreferrer"><Icon name="external-link" size={12} />{t(lang, 'footer.feeTariffs')}</a>
						<a href="https://www.istanbulbarosu.org.tr/kategori/adli-yardim" target="_blank" rel="noopener noreferrer"><Icon name="external-link" size={12} />{t(lang, 'footer.legalAid')}</a>
					</div>
				</div>
				<div class="container footer-bottom">
					<p>&copy; {new Date().getFullYear()} {siteConfig.brand.name} — {rightsText}</p>
				</div>
			</footer>
		</div>
		<HelpDeskPopup lang={lang} />
	</body>
</html>
