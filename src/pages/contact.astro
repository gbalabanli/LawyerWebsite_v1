---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CTA from '../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../config/site';
---

<BaseLayout
	title={`Contact Me | ${siteConfig.brand.name}`}
	description="Primary contact page with help desk intake, office details, and direct contact information."
	pathname="/contact"
>
	<Section title="Contact Me" lead="Use the help desk for the fastest intake, then continue in WhatsApp with your details prefilled.">
		<div class="contact-grid">
			<Card
				span="span-6"
				title="Primary Contact"
				text="Open the help desk, add your full name and a short summary, and continue in WhatsApp."
			>
				<div class="button-row">
					<a class="btn btn-primary" href={helpDeskTriggerHref}>Open Help Desk</a>
				</div>
			</Card>
			<Card span="span-6" title="Office Details" text="Alternative channels for formal communication.">
				<div class="info-row">
					<span>Email: {siteConfig.contact.email}</span>
					<span>Phone: {siteConfig.contact.phoneDisplay}</span>
					<span>Address: {siteConfig.contact.address}</span>
				</div>
			</Card>
		</div>
	</Section>

	<CTA
		title="Ready to Start?"
		text="Share your full name and a concise matter summary in the help desk to open a ready-to-send WhatsApp message."
		buttonLabel="Open Help Desk"
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>
