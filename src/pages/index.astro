---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CTA from '../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../config/site';
import { withBase } from '../utils/routing';
import { t } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

const lang: Lang = 'tr';

interface ServiceArea {
	title: string;
	tag: string;
	description: string;
	icon: string;
}

const serviceAreas: ServiceArea[] = [
	{
		title: 'Aile Hukuku',
		tag: 'aile-hukuku',
		description:
			'Bo\u015fanma, velayet, nafaka ve mal rejimi davalar\u0131 ba\u015fta olmak \u00fczere aile hukuku kaynakl\u0131 uyu\u015fmazl\u0131klarda hukuki dan\u0131\u015fmanl\u0131k ve dava takibi.',
		icon: 'family',
	},
	{
		title: 'Miras Hukuku',
		tag: 'miras-hukuku',
		description:
			'Veraset ilam\u0131, vasiyetname d\u00fczenlenmesi, tenkis davas\u0131, muris muvazaas\u0131 ve miras\u0131n reddi i\u015flemlerinde hukuki destek.',
		icon: 'scroll',
	},
	{
		title: '\u015eirketler Hukuku',
		tag: 'sirketler-hukuku',
		description:
			'Limited ve anonim \u015firket kurulu\u015fu, ortakl\u0131k s\u00f6zle\u015fmeleri, y\u00f6netim kurulu kararlar\u0131 ve hisse devir i\u015flemleri.',
		icon: 'building',
	},
	{
		title: 'Fikri M\u00fclkiyet',
		tag: 'fikri-mulkiyet',
		description:
			'Marka tescili ve korunmas\u0131, patent ba\u015fvurusu, end\u00fcstriyel tasar\u0131m ve fikri m\u00fclkiyet haklar\u0131n\u0131n ihlali durumunda hukuki ba\u015fvuru yollar\u0131.',
		icon: 'bulb',
	},
	{
		title: '\u0130\u015f Hukuku',
		tag: 'is-hukuku',
		description:
			'K\u0131dem ve ihbar tazminat\u0131 hesaplama, i\u015fe iade davalar\u0131, i\u015f s\u00f6zle\u015fmesi feshi ve i\u015f\u00e7i-i\u015fveren uyu\u015fmazl\u0131klar\u0131nda arabuluculuk ve dava s\u00fcreci.',
		icon: 'briefcase',
	},
	{
		title: 'Gayrimenkul Hukuku',
		tag: 'gayrimenkul',
		description:
			'Tapu iptali ve tescil davalar\u0131, kira uyu\u015fmazl\u0131klar\u0131, tahliye talepleri ve ortakl\u0131\u011f\u0131n giderilmesi (izale-i \u015f\u00fcyu) s\u00fcre\u00e7leri.',
		icon: 'house',
	},
	{
		title: 'Ticaret Hukuku',
		tag: 'ticaret-hukuku',
		description:
			'Ticari s\u00f6zle\u015fmeler, ticari i\u015flere ili\u015fkin uyu\u015fmazl\u0131klar, haks\u0131z rekabet ve ticari ihtarname s\u00fcre\u00e7lerinde dan\u0131\u015fmanl\u0131k.',
		icon: 'scale',
	},
	{
		title: '\u0130cra ve Tahsilat',
		tag: 'icra-tahsilat',
		description:
			'\u0130cra takibi ba\u015flatma ve takip, \u00f6denmemi\u015f fatura ve senet tahsilat\u0131, haciz i\u015flemleri ve icra ceza davalar\u0131.',
		icon: 'coin',
	},
];
---

<BaseLayout
	title={`${t(lang, 'index.eyebrow')} | ${siteConfig.brand.name}`}
	description="Hukuki hizmetler, uygulama alanlar\u0131 ve h\u0131zl\u0131 dan\u0131\u015fmanl\u0131k ba\u015fvurusu sunan sayfa."
	pathname="/"
	lang={lang}
>
	<Hero
		eyebrow={t(lang, 'index.eyebrow')}
		title={siteConfig.brand.tagline[lang]}
		summary={t(lang, 'index.summary')}
		primaryLabel={t(lang, 'index.primaryLabel')}
		primaryHref={helpDeskTriggerHref}
		secondaryLabel={t(lang, 'index.secondaryLabel')}
		secondaryHref={withBase('/blog')}
	/>

	<Section title={t(lang, 'index.practiceTitle')} lead={t(lang, 'index.practiceLead')}>
		<div class="grid service-grid">
			{
				serviceAreas.map((area) => (
					<article class="card span-4 service-card">
						<div class="service-icon-wrap">{area.icon === 'family' ? <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21v-6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v6"/><circle cx="7.5" cy="4.5" r="2.5"/><path d="M22 21v-6a2 2 0 0 0-2-2h-3"/><path d="M17 4.5a2.5 2.5 0 0 1 0 5"/><path d="M12 9a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/></svg> : area.icon === 'scroll' ? <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h8"/></svg> : area.icon === 'building' ? <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M6 21V7l6-4 6 4v14"/><path d="M10 11h4"/><path d="M10 15h4"/></svg> : area.icon === 'bulb' ? <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17v2"/><path d="M12 21h.01"/></svg> : area.icon === 'briefcase' ? <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg> : area.icon === 'house' ? <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/><path d="M8 21v-8h8v8"/></svg> : area.icon === 'scale' ? <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M3 17l3-3 3 3"/><path d="M15 17l3-3 3 3"/></svg> : <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8"/><path d="M12 8v.01"/><path d="M9.5 10.5L12 8l2.5 2.5"/><path d="M12 16v-3"/></svg>}</div>
						<h3>{area.title}</h3>
						<p>{area.description}</p>
						<a class="service-link" href={withBase('/blog?tag=' + area.tag)}>
							Devam\u0131 <span aria-hidden="true">&rarr;</span>
						</a>
					</article>
				))
			}
		</div>
	</Section>

	<Section title={t(lang, 'index.trustTitle')} lead={t(lang, 'index.trustLead')}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'index.transparentTitle')}
				text={t(lang, 'index.transparentText')}
			/>
			<Card
				span="span-6"
				title={t(lang, 'index.practicalTitle')}
				text={t(lang, 'index.practicalText')}
			/>
		</div>
	</Section>

	<Section title={t(lang, 'index.faqTitle')} lead={t(lang, 'index.faqLead')}>
		<div class="faq-list" id="faq-list">
			<details class="faq-item" name="faq">
				<summary class="faq-question">Bo\u015fanma davas\u0131 ne kadar s\u00fcrer ve nelere dikkat edilmelidir?</summary>
				<div class="faq-answer">
					<p>Anla\u015fmal\u0131 bo\u015fanma davalar\u0131 genellikle 2\u20133 ay i\u00e7inde sonu\u00e7lan\u0131rken, \u00e7eki\u015fmeli bo\u015fanma davalar\u0131 delil durumuna g\u00f6re 1\u20132 y\u0131l s\u00fcrebilir. Bo\u015fanma s\u00fcrecinde velayet, nafaka, maddi-manevi tazminat ve mal rejiminin tasfiyesi gibi hususlar\u0131n dava a\u00e7\u0131lmadan \u00f6nce de\u011ferlendirilmesi \u00f6nemlidir.</p>
				</div>
			</details>
			<details class="faq-item" name="faq">
				<summary class="faq-question">Miras payla\u015f\u0131m\u0131 nas\u0131l yap\u0131l\u0131r ve veraset ilam\u0131 nedir?</summary>
				<div class="faq-answer">
					<p>Miras payla\u015f\u0131m\u0131 i\u00e7in \u00f6ncelikle sulh hukuk mahkemesinden veraset ilam\u0131 (miras\u00e7\u0131l\u0131k belgesi) al\u0131n\u0131r. Bu belge miras\u00e7\u0131lar\u0131 ve pay oranlar\u0131n\u0131 resmile\u015ftirir. Miras\u00e7\u0131lar aras\u0131nda anla\u015fma sa\u011flanamazsa, ortakl\u0131\u011f\u0131n giderilmesi davas\u0131 a\u00e7\u0131larak malvarl\u0131\u011f\u0131 sat\u0131l\u0131r ve bedeli payla\u015ft\u0131r\u0131l\u0131r.</p>
				</div>
			</details>
			<details class="faq-item" name="faq">
				<summary class="faq-question">Limited \u015firket kurmak i\u00e7in hangi ad\u0131mlar izlenmelidir?</summary>
				<div class="faq-answer">
					<p>Limited \u015firket kurulu\u015fu i\u00e7in \u00f6ncelikle \u015firket s\u00f6zle\u015fmesi haz\u0131rlan\u0131r, noter onay\u0131 yap\u0131l\u0131r ve ticaret sicil m\u00fcd\u00fcrl\u00fc\u011f\u00fcne ba\u015fvurulur. Ticaret sicil gazetesinde ilan sonras\u0131 \u015firket t\u00fczel ki\u015filik kazan\u0131r. T\u00fcm s\u00fcre\u00e7 ortalama 1\u20132 hafta i\u00e7inde tamamlanabilir. Kurulu\u015f a\u015famas\u0131nda ortaklar aras\u0131 ili\u015fkilerin s\u00f6zle\u015fmeyle netle\u015ftirilmesi ileride \u00e7\u0131kabilecek uyu\u015fmazl\u0131klar\u0131 \u00f6nler.</p>
				</div>
			</details>
			<details class="faq-item" name="faq">
				<summary class="faq-question">Marka tescili neden \u00f6nemlidir ve nas\u0131l yap\u0131l\u0131r?</summary>
				<div class="faq-answer">
					<p>Marka tescili, markan\u0131z\u0131 \u00fc\u00e7\u00fcnc\u00fc ki\u015filerin kullan\u0131m\u0131na kar\u015f\u0131 korur ve hukuki uyu\u015fmazl\u0131klarda size m\u00fcnhas\u0131r hak sa\u011flar. T\u00fcrk Patent ve Marka Kurumu\u2019na yap\u0131lan ba\u015fvuru, inceleme ve yay\u0131n s\u00fcrecinin ard\u0131ndan tescil edilir. S\u00fcre\u00e7 yakla\u015f\u0131k 6\u201312 ay s\u00fcrer ve tescil 10 y\u0131l s\u00fcreyle ge\u00e7erlidir.</p>
				</div>
			</details>
			<details class="faq-item" name="faq">
				<summary class="faq-question">K\u0131dem tazminat\u0131na hangi durumlarda hak kazan\u0131l\u0131r?</summary>
				<div class="faq-answer">
					<p>K\u0131dem tazminat\u0131, en az bir y\u0131l \u00e7al\u0131\u015fm\u0131\u015f i\u015f\u00e7inin i\u015f s\u00f6zle\u015fmesinin belirli durumlarda sona ermesi halinde \u00f6denir. \u0130\u015f\u00e7inin kendi iste\u011fiyle istifa etmesi genel olarak tazminat hakk\u0131 do\u011furmazken, i\u015fveren taraf\u0131ndan haks\u0131z fesih, i\u015f\u00e7inin hakl\u0131 feshi, askerlik, emeklilik veya evlilik (\u00e7al\u0131\u015fan kad\u0131n i\u00e7in) gibi durumlarda k\u0131dem tazminat\u0131 \u00f6denir.</p>
				</div>
			</details>
			<details class="faq-item" name="faq">
				<summary class="faq-question">Kira uyu\u015fmazl\u0131klar\u0131nda kirac\u0131 ve malik hangi haklara sahiptir?</summary>
				<div class="faq-answer">
					<p>Kirac\u0131n\u0131n en \u00f6nemli hakk\u0131 kira s\u00f6zle\u015fmesi boyunca ta\u015f\u0131nmaz\u0131 kullanma ve kira art\u0131\u015f\u0131n\u0131n kanuni s\u0131n\u0131rlar i\u00e7inde kalmas\u0131n\u0131 talep etmektir. Malik ise kira bedelinin \u00f6denmemesi, gereksinim veya yeniden in\u015fa sebebiyle tahliye davas\u0131 a\u00e7abilir. Kira uyu\u015fmazl\u0131klar\u0131nda arabuluculuk dava \u015fart\u0131 olup, s\u00fcrecin ba\u015f\u0131nda uzla\u015fma yoluna gidilmesi zorunludur.</p>
				</div>
			</details>
			<details class="faq-item" name="faq">
				<summary class="faq-question">Ticari s\u00f6zle\u015fmelerde bulunmas\u0131 gereken temel unsurlar nelerdir?</summary>
				<div class="faq-answer">
					<p>Ticari s\u00f6zle\u015fmelerde taraflar\u0131n kimlik bilgileri, s\u00f6zle\u015fme konusu, bedel ve \u00f6deme ko\u015fullar\u0131, teslimat \u015fartlar\u0131, gizlilik h\u00fck\u00fcmleri, uyu\u015fmazl\u0131k durumunda yetkili mahkeme ve uygulanacak hukuk a\u00e7\u0131k\u00e7a belirtilmelidir. Eksik veya belirsiz h\u00fck\u00fcmler ileride ciddi uyu\u015fmazl\u0131klara yol a\u00e7abilir. Bu nedenle her s\u00f6zle\u015fmenin bir avukat taraf\u0131ndan incelenmesi \u00f6nerilir.</p>
				</div>
			</details>
			<details class="faq-item" name="faq">
				<summary class="faq-question">\u0130cra takibi nas\u0131l ba\u015flat\u0131l\u0131r ve hangi a\u015famalardan olu\u015fur?</summary>
				<div class="faq-answer">
					<p>\u0130cra takibi, alacakl\u0131n\u0131n yetkili icra dairesine ba\u015fvurusu ile ba\u015flar. Bor\u00e7luya g\u00f6nderilen \u00f6deme emrine itiraz edilmezse takip kesinle\u015fir ve haciz a\u015famas\u0131na ge\u00e7ilir. Bor\u00e7lu itiraz ederse takip durur ve alacakl\u0131n\u0131n itiraz\u0131n kald\u0131r\u0131lmas\u0131 veya menfi tespit davas\u0131 a\u00e7mas\u0131 gerekir. \u0130cra takibinde zaman\u0131nda hareket etmek alacak tahsilat\u0131nda kritik \u00f6neme sahiptir.</p>
				</div>
			</details>
		</div>
	</Section>

	<CTA
		title={t(lang, 'index.ctaTitle')}
		text={t(lang, 'index.ctaText')}
		buttonLabel={t(lang, 'index.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>

<style>
	.service-grid {
		row-gap: var(--space-5);
	}

	.service-card {
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.service-icon-wrap {
		margin-bottom: 0.75rem;
		color: var(--button-secondary-text);
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		padding: 0.25rem;
	}

	.service-card h3 {
		margin-bottom: 0.5rem;
	}

	.service-card p {
		flex: 1;
		margin-bottom: 1rem;
		font-size: 0.9rem;
	}

	.service-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--button-secondary-text);
		text-decoration: none;
		padding: 0.35rem 0;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
		align-self: flex-start;
	}

	.service-link:hover {
		border-bottom-color: var(--button-secondary-text);
	}

	.faq-list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.faq-item {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--card-bg);
		overflow: hidden;
	}

	.faq-item[open] {
		background: var(--surface-bg);
	}

	.faq-question {
		padding: 1rem 1.25rem;
		font-family: var(--font-heading);
		font-weight: 600;
		font-size: 1rem;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		user-select: none;
		list-style: none;
	}

	.faq-question::-webkit-details-marker {
		display: none;
	}

	.faq-question::after {
		content: '+';
		font-size: 1.25rem;
		font-weight: 400;
		color: var(--button-secondary-text);
		flex-shrink: 0;
		transition: transform 0.2s;
	}

	.faq-item[open] .faq-question::after {
		content: '\u2212';
	}

	.faq-answer {
		padding: 0 1.25rem 1rem;
		font-size: 0.9rem;
		line-height: 1.65;
	}

	.faq-answer p {
		margin: 0;
	}
</style>
