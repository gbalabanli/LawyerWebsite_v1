---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import { helpDeskTriggerHref, siteConfig } from '../config/site';
import { withBase } from '../utils/routing';
import type { Lang } from '../i18n/ui';

const pathname = Astro.url.pathname;
const isEn = pathname.startsWith('/en/');
const lang: Lang = isEn ? 'en' : 'tr';

const t = {
	title: isEn ? `Page Not Found | ${siteConfig.brand.name}` : `Sayfa Bulunamadı | ${siteConfig.brand.name}`,
	desc: isEn
		? 'The page you are looking for could not be found. Return to our homepage or contact us to find the right address.'
		: 'Aradığınız sayfa bulunamadı veya taşınmış olabilir. Ana sayfamıza dönerek veya bizimle iletişime geçerek doğru adrese yönlenebilirsiniz.',
	lead: isEn ? "We couldn't find that page." : 'Aradığınız sayfayı bulamadık.',
	text: isEn
		? 'It may have been removed, renamed, or is temporarily unavailable. Try one of the links below.'
		: 'Sayfa kaldırılmış, adresi değişmiş veya geçici olarak kullanılamıyor olabilir. Aşağıdaki bağlantılardan yararlanabilirsiniz.',
	home: isEn ? 'Home' : 'Ana Sayfa',
	services: isEn ? 'Practice Areas' : 'Çalışma Alanları',
	blog: 'Blog',
	contact: isEn ? 'Contact' : 'İletişim',
	help1: isEn ? 'Need legal assistance?' : 'Hukuki destek mi gerekiyor?',
	help2: isEn ? 'Reach us on WhatsApp' : 'WhatsApp üzerinden bize ulaşın',
};

const homeHref = isEn ? withBase('/en/') : withBase('/');
const servicesHref = isEn ? withBase('/en/services') : withBase('/hizmetler');
const blogHref = isEn ? withBase('/en/blog') : withBase('/blog');
const contactHref = isEn ? withBase('/en/contact') : withBase('/iletisim');
---

<BaseLayout
	title={t.title}
	description={t.desc}
	pathname={isEn ? '/en/404' : '/404'}
	lang={lang}
>
	<Section>
		<div class="not-found">
			<h1 class="not-found-code">404</h1>
			<p class="not-found-lead">{t.lead}</p>
			<p class="not-found-text">{t.text}</p>
			<div class="not-found-links">
				<a href={homeHref} class="not-found-btn not-found-btn--primary">{t.home}</a>
				<a href={servicesHref} class="not-found-btn">{t.services}</a>
				<a href={blogHref} class="not-found-btn">{t.blog}</a>
				<a href={contactHref} class="not-found-btn">{t.contact}</a>
			</div>
			<p class="not-found-help">{t.help1} <a href={helpDeskTriggerHref} class="not-found-whatsapp">{t.help2}</a>.</p>
		</div>
	</Section>
</BaseLayout>

<style>
	.not-found {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: var(--space-8) var(--space-4);
		max-width: 36rem;
		margin: 0 auto;
	}

	.not-found-code {
		font-size: clamp(4rem, 12vw, 7rem);
		font-family: var(--font-heading);
		font-weight: 700;
		color: var(--button-secondary-text);
		line-height: 1;
		margin: 0 0 var(--space-3);
	}

	.not-found-lead {
		font-size: 1.25rem;
		font-weight: 600;
		margin: 0 0 var(--space-2);
	}

	.not-found-text {
		color: var(--color-muted);
		margin: 0 0 var(--space-6);
		font-size: 0.95rem;
		max-width: 28rem;
	}

	.not-found-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
		margin-bottom: var(--space-5);
	}

	.not-found-btn {
		display: inline-block;
		padding: 0.6rem 1.5rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		font-size: 0.9rem;
		font-weight: 500;
		text-decoration: none;
		color: var(--text-color);
		transition: background 0.2s, border-color 0.2s;
	}

	.not-found-btn:hover {
		background: var(--card-bg);
		border-color: var(--button-secondary-text);
	}

	.not-found-btn--primary {
		background: var(--button-primary-bg);
		color: var(--button-primary-text);
		border-color: var(--button-primary-bg);
	}

	.not-found-btn--primary:hover {
		opacity: 0.9;
		background: var(--button-secondary-text);
		border-color: var(--button-secondary-text);
	}

	.not-found-help {
		font-size: 0.9rem;
		color: var(--color-muted);
		margin: 0;
	}

	.not-found-whatsapp {
		color: var(--button-secondary-text);
		font-weight: 600;
		text-decoration: none;
	}

	.not-found-whatsapp:hover {
		text-decoration: underline;
	}
</style>
