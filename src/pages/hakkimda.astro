---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CTA from '../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../config/site';
import { withBase } from '../utils/routing';
import { t } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

const lang: Lang = 'tr';
---

<BaseLayout
	title={`${t(lang, 'about.eyebrow')} | ${siteConfig.brand.name}`}
	description="Avukat Barış C. Balabanlı profili, eğitim, mesleki üyelikler ve çalışma tarzı. Medeni ve ticari hukuk alanlarında uzman, İstanbul merkezli avukat."
	pathname="/hakkimda"
	lang={lang}
>
	<section class="profile-hero">
		<div class="profile-hero-text">
			<p class="eyebrow">{t(lang, 'about.eyebrow')}</p>
			<h1>{t(lang, 'about.heroTitle')}</h1>
			<p>{t(lang, 'about.heroSummary')}</p>
		</div>
		<img class="profile-photo" src={withBase('/images/profile.jpg')} alt="Av. Bar\u0131\u015f C. Balabanl\u0131" width="160" height="160" loading="lazy" />
	</section>

	<Section title={t(lang, 'about.profileTitle')} lead={siteConfig.brand.aboutLong[lang]}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'about.profileTitle')}
				text={t(lang, 'about.profileText')}
			/>
			<Card
				span="span-6"
				title={t(lang, 'about.workingStyleTitle')}
				text={t(lang, 'about.workingStyleText')}
			/>
		</div>
	</Section>

	<Section title={t(lang, 'about.eduTitle')}>
		<div class="grid">
			<Card icon="graduation-cap" title={t(lang, 'about.eduTitle')} text={t(lang, 'about.eduText')} />
			<Card icon="award" title={t(lang, 'about.membershipTitle')} text={t(lang, 'about.membershipText')} />
			<Card icon="globe" title={t(lang, 'about.langTitle')} text={t(lang, 'about.langText')} />
		</div>
	</Section>

	<Section title={t(lang, 'about.qualTitle')} lead={t(lang, 'about.qualLead')}>
		<div class="grid">
			<Card icon="scale" title={t(lang, 'about.courtroomTitle')} text={t(lang, 'about.courtroomText')} />
			<Card icon="scroll" title={t(lang, 'about.contractTitle')} text={t(lang, 'about.contractText')} />
			<Card icon="handshake" title={t(lang, 'about.clientTitle')} text={t(lang, 'about.clientText')} />
		</div>
	</Section>

	<CTA
		title={t(lang, 'about.ctaTitle')}
		text={t(lang, 'about.ctaText')}
		buttonLabel={t(lang, 'about.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Barış C. Balabanlı',
	givenName: 'Barış',
	familyName: 'Balabanlı',
	jobTitle: 'Avukat',
	url: siteConfig.seo.siteUrl,
	email: siteConfig.contact.email,
	telephone: siteConfig.contact.phoneDisplay,
	alumniOf: {
		'@type': 'CollegeOrUniversity',
		name: 'Kadir Has Üniversitesi Hukuk Fakültesi',
	},
	knowsAbout: [
		{ '@type': 'Thing', name: 'Aile Hukuku' },
		{ '@type': 'Thing', name: 'Miras Hukuku' },
		{ '@type': 'Thing', name: 'Şirketler Hukuku' },
		{ '@type': 'Thing', name: 'Fikri Mülkiyet Hukuku' },
		{ '@type': 'Thing', name: 'İş Hukuku' },
		{ '@type': 'Thing', name: 'Gayrimenkul Hukuku' },
		{ '@type': 'Thing', name: 'Ticaret Hukuku' },
		{ '@type': 'Thing', name: 'İcra ve Tahsilat Hukuku' },
		{ '@type': 'Thing', name: 'E-Spor Hukuku' },
	],
})} />
