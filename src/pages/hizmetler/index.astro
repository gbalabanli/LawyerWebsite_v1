---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Section from '../../components/Section.astro';
import CTA from '../../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../../config/site';
import { serviceAreas } from '../../config/services';
import { withBase } from '../../utils/routing';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'tr';
---

<BaseLayout
	title={`Hizmetler | ${siteConfig.brand.name}`}
	description="Balabanlı Hukuk Bürosu'nun tüm hukuki hizmet alanları: Aile Hukuku, Miras Hukuku, Şirketler Hukuku, Fikri Mülkiyet, İş Hukuku, Gayrimenkul, Ticaret Hukuku, İcra ve E-Spor Hukuku. Detaylı bilgi ve danışmanlık için sayfaları inceleyin."
	pathname="/hizmetler"
	lang={lang}
>
	<Section title="Hizmet Alanlarımız" lead="Aşağıda hukuki danışmanlık ve dava takibi sunduğumuz başlıca alanları bulabilirsiniz. Her hizmet alanı hakkında detaylı bilgi için ilgili sayfayı ziyaret edebilirsiniz.">
		<div class="grid service-grid">
			{
				serviceAreas.map((area) => (
					<article class="card span-4 service-card">
						<div class="service-icon-wrap"><Icon name={area.icon} /></div>
						<h3>{area.title}</h3>
						<p>{area.description}</p>
						<a class="service-link" href={withBase(`/hizmetler/${area.slug}`)}>
							Detaylı Bilgi <Icon name="arrow-right" size={14} />
						</a>
					</article>
				))
			}
		</div>
	</Section>

	<CTA
		title="Hukuki Danışmanlık İçin Bize Ulaşın"
		text="Hangi hukuki alanda destek ihtiyacınız olursa olsun, WhatsApp üzerinden bize ulaşarak randevu talep edebilirsiniz."
		buttonLabel="Danışmanlık Alın"
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>

<style>
	.service-grid {
		row-gap: var(--space-5);
	}

	.service-card {
		display: flex;
		flex-direction: column;
		position: relative;
	}

	.service-icon-wrap {
		margin-bottom: 0.75rem;
		color: var(--button-secondary-text);
		width: 2rem;
		height: 2rem;
		display: flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		padding: 0.25rem;
	}

	.service-card h3 {
		margin-bottom: 0.5rem;
	}

	.service-card p {
		flex: 1;
		margin-bottom: 1rem;
		font-size: 0.9rem;
	}

	.service-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		font-size: 0.9rem;
		font-weight: 600;
		color: var(--button-secondary-text);
		text-decoration: none;
		padding: 0.35rem 0;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
		align-self: flex-start;
	}

	.service-link:hover {
		border-bottom-color: var(--button-secondary-text);
	}
</style>
