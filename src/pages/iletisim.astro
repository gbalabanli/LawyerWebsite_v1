---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CTA from '../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../config/site';
import { t } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

const lang: Lang = 'tr';
const mapsUrl = 'https://www.google.com/maps/place//data=!4m2!3m1!1s0x14cab9ae529fa8d3:0x3626d5a13f4e3375';
const linkedinUrl = 'https://www.linkedin.com/in/bar%C4%B1%C5%9F-cem-balabanl%C4%B1-515b2020a';
---

<BaseLayout
	title={`${t(lang, 'contact.eyebrow')} | ${siteConfig.brand.name}`}
	description="Balabanlı Hukuk Bürosu iletişim sayfası. WhatsApp, e-posta ve ofis bilgileri üzerinden hukuki danışmanlık randevusu ve başvuru için bize ulaşın."
	pathname="/iletisim"
	lang={lang}
>
	<section class="hero">
		<div>
			<p class="eyebrow">{t(lang, 'contact.eyebrow')}</p>
			<h1>{siteConfig.brand.name}</h1>
			<p>{t(lang, 'contact.lead')}</p>
		</div>
	</section>

	<Section title={t(lang, 'contact.primaryTitle')}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'contact.primaryTitle')}
				text={t(lang, 'contact.primaryText')}
			>
				<div class="contact-card-icon"><Icon name="message-circle" size={28} /></div>
				<div class="button-row">
					<a class="btn btn-primary" href={helpDeskTriggerHref}>{t(lang, 'contact.primaryButton')}</a>
				</div>
			</Card>
			<Card span="span-6" title={t(lang, 'contact.officeTitle')} text={t(lang, 'contact.officeText')}>
				<div class="contact-card-icon"><Icon name="map-pin" size={28} /></div>
				<div class="info-row">
					<span><Icon name="map-pin" size={14} /><strong>{t(lang, 'contact.addressLabel')}:</strong> {siteConfig.contact.address}</span>
					<a class="btn btn-secondary" href={mapsUrl} target="_blank" rel="noopener noreferrer"><Icon name="external-link" size={14} />{t(lang, 'contact.mapLink')}</a>
				</div>
			</Card>
		</div>
	</Section>

	<Section title={t(lang, 'contact.directTitle')} lead={t(lang, 'contact.directText')}>
		<div class="grid">
			<Card title="Form Gönder" text="Hukuki danışmanlık talebinizi form doldurarak iletin, WhatsApp üzerinden yanıtlayalım.">
				<div class="contact-card-icon"><Icon name="mail" size={28} /></div>
				<div class="button-row">
					<a class="btn btn-primary" href={helpDeskTriggerHref}>Formu Doldur</a>
				</div>
			</Card>
			<Card title={t(lang, 'contact.hoursTitle')} text={t(lang, 'contact.hoursText')}>
				<div class="contact-card-icon"><Icon name="clock" size={28} /></div>
			</Card>
			<Card title="LinkedIn" text="Av. Barış C. Balabanlı">
				<div class="contact-card-icon"><Icon name="linkedin" size={28} /></div>
				<div class="button-row">
					<a class="btn btn-secondary" href={linkedinUrl} target="_blank" rel="noopener noreferrer"><Icon name="external-link" size={14} />LinkedIn'de Gör</a>
				</div>
			</Card>
		</div>
	</Section>

	<CTA
		title={t(lang, 'contact.ctaTitle')}
		text={t(lang, 'contact.ctaText')}
		buttonLabel={t(lang, 'contact.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'ContactPage',
	name: `İletişim | ${siteConfig.brand.name}`,
	description: 'Balabanlı Hukuk Bürosu iletişim sayfası. WhatsApp, e-posta ve ofis bilgileri.',
	url: `${siteConfig.seo.siteUrl}/iletisim`,
})} />
