---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CTA from '../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../config/site';
import { t } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

const lang: Lang = 'tr';
const mapsUrl = 'https://www.google.com/maps/place//data=!4m2!3m1!1s0x14cab9ae529fa8d3:0x3626d5a13f4e3375';
const linkedinUrl = 'https://www.linkedin.com/in/bar%C4%B1%C5%9F-cem-balabanl%C4%B1-515b2020a';
---

<BaseLayout
	title={`${t(lang, 'contact.eyebrow')} | ${siteConfig.brand.name}`}
	description="\u0130leti\u015fim sayfas\u0131: WhatsApp, e-posta, telefon ve ofis bilgileri ile hukuki dan\u0131\u015fmanl\u0131k ba\u015fvurusu."
	pathname="/iletisim"
	lang={lang}
>
	<section class="hero">
		<div>
			<p class="eyebrow">{t(lang, 'contact.eyebrow')}</p>
			<h1>{siteConfig.brand.name}</h1>
			<p>{t(lang, 'contact.lead')}</p>
		</div>
	</section>

	<Section title={t(lang, 'contact.primaryTitle')}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'contact.primaryTitle')}
				text={t(lang, 'contact.primaryText')}
			>
				<div class="button-row">
					<a class="btn btn-primary" href={helpDeskTriggerHref}>{t(lang, 'contact.primaryButton')}</a>
				</div>
			</Card>
			<Card span="span-6" title={t(lang, 'contact.officeTitle')} text={t(lang, 'contact.officeText')}>
				<div class="info-row">
					<span><strong>{t(lang, 'contact.addressLabel')}:</strong> {siteConfig.contact.address}</span>
					<a class="btn btn-secondary" href={mapsUrl} target="_blank" rel="noopener noreferrer">{t(lang, 'contact.mapLink')}</a>
				</div>
			</Card>
		</div>
	</Section>

	<Section title={t(lang, 'contact.directTitle')} lead={t(lang, 'contact.directText')}>
		<div class="grid">
			<Card title="Form G\u00f6nder" text="Hukuki dan\u0131\u015fmanl\u0131k talebinizi form doldurarak iletin, WhatsApp \u00fczerinden yan\u0131tlayal\u0131m.">
				<div class="button-row">
					<a class="btn btn-primary" href={helpDeskTriggerHref}>Formu Doldur</a>
				</div>
			</Card>
			<Card title={t(lang, 'contact.hoursTitle')} text={t(lang, 'contact.hoursText')} />
			<Card title="LinkedIn" text="Av. Bar\u0131\u015f C. Balabanl\u0131">
				<div class="button-row">
					<a class="btn btn-secondary" href={linkedinUrl} target="_blank" rel="noopener noreferrer">LinkedIn'de G\u00f6r</a>
				</div>
			</Card>
		</div>
	</Section>

	<CTA
		title={t(lang, 'contact.ctaTitle')}
		text={t(lang, 'contact.ctaText')}
		buttonLabel={t(lang, 'contact.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>
