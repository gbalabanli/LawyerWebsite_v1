---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import CTA from '../../components/CTA.astro';
import { getBrandName, helpDeskTriggerHref, siteConfig } from '../../config/site';
import { getServiceAreas } from '../../config/services';
import { withBase } from '../../utils/routing';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'en';
const brandName = getBrandName(lang);
const knowsAbout = getServiceAreas(lang).map((area) => ({
	'@type': 'Thing',
	name: area.title,
}));
---

<BaseLayout
	title={`${t(lang, 'about.eyebrow')} | ${brandName}`}
	description="Attorney Baris C. Balabanli profile: legal education, professional memberships, working approach and practice focus in civil and commercial law."
	pathname="/en/about"
	lang={lang}
	lastModified="2026-06-11"
>
	<section class="profile-hero">
		<div class="profile-hero-text">
			<p class="eyebrow">{t(lang, 'about.eyebrow')}</p>
			<h1>{t(lang, 'about.heroTitle')}</h1>
			<p>{t(lang, 'about.heroSummary')}</p>
		</div>
		<img class="profile-photo" src={withBase('/images/profile.jpg')} alt="Attorney Baris C. Balabanli" width="160" height="160" loading="lazy" />
	</section>

	<Section title={t(lang, 'about.profileTitle')} lead={siteConfig.brand.aboutLong[lang]}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'about.profileTitle')}
				text={t(lang, 'about.profileText')}
			/>
			<Card
				span="span-6"
				title={t(lang, 'about.workingStyleTitle')}
				text={t(lang, 'about.workingStyleText')}
			/>
		</div>
	</Section>

	<Section title={t(lang, 'about.eduTitle')}>
		<div class="grid">
			<Card title={t(lang, 'about.eduTitle')} text={t(lang, 'about.eduText')} />
			<Card title={t(lang, 'about.membershipTitle')} text={t(lang, 'about.membershipText')} />
			<Card title={t(lang, 'about.langTitle')} text={t(lang, 'about.langText')} />
		</div>
	</Section>

	<Section title={t(lang, 'about.qualTitle')} lead={t(lang, 'about.qualLead')}>
		<div class="grid">
			<Card title={t(lang, 'about.courtroomTitle')} text={t(lang, 'about.courtroomText')} />
			<Card title={t(lang, 'about.contractTitle')} text={t(lang, 'about.contractText')} />
			<Card title={t(lang, 'about.clientTitle')} text={t(lang, 'about.clientText')} />
		</div>
	</Section>

	<CTA
		title={t(lang, 'about.ctaTitle')}
		text={t(lang, 'about.ctaText')}
		buttonLabel={t(lang, 'about.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Baris C. Balabanli',
	givenName: 'Baris',
	familyName: 'Balabanli',
	jobTitle: 'Attorney',
	description: siteConfig.brand.aboutLong.en,
	url: `${siteConfig.seo.siteUrl}/en/about`,
	email: siteConfig.contact.email,
	telephone: siteConfig.contact.phoneDisplay,
	image: new URL(withBase('/images/profile.jpg'), siteConfig.seo.siteUrl).toString(),
	alumniOf: {
		'@type': 'CollegeOrUniversity',
		name: 'Kadir Has University Faculty of Law',
	},
	sameAs: [
		'https://www.linkedin.com/in/bar%C4%B1%C5%9F-cem-balabanl%C4%B1-515b2020a',
	],
	knowsAbout,
})} />
