---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import CTA from '../../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../../config/site';
import { withBase } from '../../utils/routing';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'en';
---

<BaseLayout
	title={`${t(lang, 'about.eyebrow')} | ${siteConfig.brand.name}`}
	description="Attorney Barış C. Balabanlı profile: legal education, professional memberships, working approach and practice focus in civil and commercial law. Istanbul-based attorney."
	pathname="/en/about"
	lang={lang}
	lastModified="2026-06-11"
>
	<section class="profile-hero">
		<div class="profile-hero-text">
			<p class="eyebrow">{t(lang, 'about.eyebrow')}</p>
			<h1>{t(lang, 'about.heroTitle')}</h1>
			<p>{t(lang, 'about.heroSummary')}</p>
		</div>
		<img class="profile-photo" src={withBase('/images/profile.jpg')} alt="Attorney Bar\u0131\u015f C. Balabanl\u0131" width="160" height="160" loading="lazy" />
	</section>

	<Section title={t(lang, 'about.profileTitle')} lead={siteConfig.brand.aboutLong[lang]}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'about.profileTitle')}
				text={t(lang, 'about.profileText')}
			/>
			<Card
				span="span-6"
				title={t(lang, 'about.workingStyleTitle')}
				text={t(lang, 'about.workingStyleText')}
			/>
		</div>
	</Section>

	<Section title={t(lang, 'about.eduTitle')}>
		<div class="grid">
			<Card title={t(lang, 'about.eduTitle')} text={t(lang, 'about.eduText')} />
			<Card title={t(lang, 'about.membershipTitle')} text={t(lang, 'about.membershipText')} />
			<Card title={t(lang, 'about.langTitle')} text={t(lang, 'about.langText')} />
		</div>
	</Section>

	<Section title={t(lang, 'about.qualTitle')} lead={t(lang, 'about.qualLead')}>
		<div class="grid">
			<Card title={t(lang, 'about.courtroomTitle')} text={t(lang, 'about.courtroomText')} />
			<Card title={t(lang, 'about.contractTitle')} text={t(lang, 'about.contractText')} />
			<Card title={t(lang, 'about.clientTitle')} text={t(lang, 'about.clientText')} />
		</div>
	</Section>

	<CTA
		title={t(lang, 'about.ctaTitle')}
		text={t(lang, 'about.ctaText')}
		buttonLabel={t(lang, 'about.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Bar\u0131\u015f C. Balabanl\u0131',
	jobTitle: 'Avukat',
	description: siteConfig.brand.aboutLong.en,
	url: `${siteConfig.seo.siteUrl}/en/about`,
	image: new URL(withBase('/images/profile.jpg'), siteConfig.seo.siteUrl).toString(),
	sameAs: [
		'https://www.linkedin.com/in/bar%C4%B1%C5%9F-cem-balabanl%C4%B1-515b2020a',
	],
	knowsAbout: [
		{ '@type': 'LegalService', name: 'Aile Hukuku' },
		{ '@type': 'LegalService', name: 'Miras Hukuku' },
		{ '@type': 'LegalService', name: 'Şirketler Hukuku' },
		{ '@type': 'LegalService', name: 'Fikri Mülkiyet' },
		{ '@type': 'LegalService', name: 'İş Hukuku' },
		{ '@type': 'LegalService', name: 'Gayrimenkul Hukuku' },
		{ '@type': 'LegalService', name: 'Ticaret Hukuku' },
		{ '@type': 'LegalService', name: 'İcra ve Tahsilat' },
		{ '@type': 'LegalService', name: 'E-Spor Hukuku' },
	],
})} />
