---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CTA from '../../../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../../../config/site';
import { withBase } from '../../../utils/routing';
import { t, getDateLocale, type Lang } from '../../../i18n/ui';

interface StaticPath {
	params: { slug: string };
	props: { post: CollectionEntry<'posts'> };
}

export async function getStaticPaths(): Promise<StaticPath[]> {
	const posts = await getCollection('posts');
	const enPosts = posts.filter((post) => post.data.lang === 'en');

	return enPosts.map((post) => {
		const slug = post.id.replace(/^en\//, '');
		return {
			params: { slug },
			props: { post },
		};
	});
}

const lang: Lang = 'en';
const { post } = Astro.props;
const { Content, headings } = await render(post);

const sortedPosts = (await getCollection('posts'))
	.filter((p) => p.data.lang === 'en')
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const relatedPosts = sortedPosts
	.filter((item) => item.id !== post.id)
	.filter((item) => item.data.tags.some((tag) => post.data.tags.includes(tag)))
	.slice(0, 3);

const dateLocale = getDateLocale(lang);

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: post.data.title,
	description: post.data.description,
	datePublished: post.data.date.toISOString(),
	author: {
		'@type': 'Person',
		name: post.data.author,
	},
	publisher: {
		'@type': 'Organization',
		name: siteConfig.brand.name,
	},
	mainEntityOfPage: `${siteConfig.seo.siteUrl}/en/blog/${post.id.replace(/^en\//, '')}`,
};
---

<BaseLayout
	title={`${post.data.title} | ${siteConfig.brand.name}`}
	description={post.data.description}
	pathname={`/en/blog/${post.id.replace(/^en\//, '')}`}
	ogType="article"
	lang={lang}
	article={{ publishedTime: post.data.date.toISOString(), tags: post.data.tags }}
>
	<article class="article">
		<p class="eyebrow">{t(lang, 'blog.postEyebrow')}</p>
		<h1>{post.data.title}</h1>
		<div class="blog-meta">
			<span>
				{post.data.date.toLocaleDateString(dateLocale, { year: 'numeric', month: 'long', day: 'numeric' })}
			</span>
			<span>{post.data.author}</span>
		</div>
		<div class="meta-list">
			{post.data.tags.map((tag) => <span class="meta-pill">{tag}</span>)}
		</div>

		{
			headings.length > 0 && (
				<aside class="toc">
					<h2>{t(lang, 'blog.contents')}</h2>
					<ul>
						{headings.map((heading) => <li><a href={`#${heading.slug}`}>{heading.text}</a></li>)}
					</ul>
				</aside>
			)
		}

		<div class="article-content">
			<Content />
		</div>
	</article>

	{
		relatedPosts.length > 0 && (
			<section class="section">
				<div class="section-heading">
					<h2>{t(lang, 'blog.relatedTitle')}</h2>
					<p class="section-lead">{t(lang, 'blog.relatedLead')}</p>
				</div>
				<div class="blog-list">
					{relatedPosts.map((related) => (
						<article class="card blog-card">
							<h3><a href={withBase(`/en/blog/${related.id.replace(/^en\//, '')}`)}>{related.data.title}</a></h3>
							<p>{related.data.description}</p>
						</article>
					))}
				</div>
			</section>
		)
	}

	<CTA
		title={t(lang, 'blog.ctaTitle')}
		text={t(lang, 'blog.ctaText')}
		buttonLabel={t(lang, 'blog.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>

	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
