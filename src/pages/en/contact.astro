---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import CTA from '../../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../../config/site';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'en';
const whatsappUrl = `https://wa.me/${siteConfig.contact.whatsappNumberE164}`;
const mailtoUrl = `mailto:${siteConfig.contact.email}`;
const mapsUrl = 'https://maps.google.com/?q=Istanbul+Turkiye';
---

<BaseLayout
	title={`${t(lang, 'contact.eyebrow')} | ${siteConfig.brand.name}`}
	description="Contact page: WhatsApp, email, phone, and office details for legal consultation intake."
	pathname="/en/contact"
	lang={lang}
>
	<section class="hero">
		<div>
			<p class="eyebrow">{t(lang, 'contact.eyebrow')}</p>
			<h1>{siteConfig.brand.name}</h1>
			<p>{t(lang, 'contact.lead')}</p>
		</div>
	</section>

	<Section title={t(lang, 'contact.primaryTitle')}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'contact.primaryTitle')}
				text={t(lang, 'contact.primaryText')}
			>
				<div class="button-row">
					<a class="btn btn-primary" href={helpDeskTriggerHref}>{t(lang, 'contact.primaryButton')}</a>
				</div>
			</Card>
			<Card span="span-6" title={t(lang, 'contact.officeTitle')} text={t(lang, 'contact.officeText')}>
				<div class="info-row">
					<span><strong>{t(lang, 'contact.emailLabel')}:</strong> {siteConfig.contact.email}</span>
					<span><strong>{t(lang, 'contact.phoneLabel')}:</strong> {siteConfig.contact.phoneDisplay}</span>
					<span><strong>{t(lang, 'contact.addressLabel')}:</strong> {siteConfig.contact.address}</span>
					<a class="btn btn-secondary" href={mapsUrl} target="_blank" rel="noopener noreferrer">{t(lang, 'contact.mapLink')}</a>
				</div>
			</Card>
		</div>
	</Section>

	<Section title={t(lang, 'contact.directTitle')} lead={t(lang, 'contact.directText')}>
		<div class="grid">
			<Card title={t(lang, 'contact.whatsappTitle')} text={t(lang, 'contact.whatsappText')}>
				<div class="button-row">
					<a class="btn btn-primary" href={whatsappUrl} target="_blank" rel="noopener noreferrer">{t(lang, 'contact.whatsappButton')}</a>
				</div>
			</Card>
			<Card title={t(lang, 'contact.emailTitle')} text={t(lang, 'contact.emailText')}>
				<div class="button-row">
					<a class="btn btn-secondary" href={mailtoUrl}>{t(lang, 'contact.emailButton')}</a>
				</div>
			</Card>
			<Card title={t(lang, 'contact.hoursTitle')} text={t(lang, 'contact.hoursText')} />
		</div>
	</Section>

	<CTA
		title={t(lang, 'contact.ctaTitle')}
		text={t(lang, 'contact.ctaText')}
		buttonLabel={t(lang, 'contact.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>
