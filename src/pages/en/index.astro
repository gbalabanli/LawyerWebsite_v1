---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import CTA from '../../components/CTA.astro';
import { helpDeskTriggerHref, siteConfig } from '../../config/site';
import { withBase } from '../../utils/routing';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/ui';

const lang: Lang = 'en';
---

<BaseLayout
	title={`${t(lang, 'index.eyebrow')} | ${siteConfig.brand.name}`}
	description="Istanbul-based lawyer for foreigners and businesses in Turkey, advising on immigration, real estate, citizenship, inheritance, company formation, and disputes."
	pathname="/en/"
	lang={lang}
	lastModified="2026-06-11"
>
	<Hero
		eyebrow={t(lang, 'index.eyebrow')}
		title={siteConfig.brand.tagline[lang]}
		summary={t(lang, 'index.summary')}
		primaryLabel={t(lang, 'index.primaryLabel')}
		primaryHref={helpDeskTriggerHref}
		secondaryLabel={t(lang, 'index.secondaryLabel')}
		secondaryHref={withBase('/en/blog')}
	/>

	<Section title={t(lang, 'index.practiceTitle')} lead={t(lang, 'index.practiceLead')}>
		<div class="grid">
			<Card title={t(lang, 'index.civilLitigation')} text={t(lang, 'index.civilLitigationText')} />
			<Card title={t(lang, 'index.contractReview')} text={t(lang, 'index.contractReviewText')} />
			<Card title={t(lang, 'index.businessAdvisory')} text={t(lang, 'index.businessAdvisoryText')} />
		</div>
	</Section>

	<Section title={t(lang, 'index.trustTitle')} lead={t(lang, 'index.trustLead')}>
		<div class="grid">
			<Card
				span="span-6"
				title={t(lang, 'index.transparentTitle')}
				text={t(lang, 'index.transparentText')}
			/>
			<Card
				span="span-6"
				title={t(lang, 'index.practicalTitle')}
				text={t(lang, 'index.practicalText')}
			/>
		</div>
	</Section>

	<CTA
		title={t(lang, 'index.ctaTitle')}
		text={t(lang, 'index.ctaText')}
		buttonLabel={t(lang, 'index.ctaButton')}
		buttonHref={helpDeskTriggerHref}
	/>
</BaseLayout>
