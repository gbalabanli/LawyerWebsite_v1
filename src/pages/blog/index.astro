---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import Section from '../../components/Section.astro';
import BlogCard from '../../components/BlogCard.astro';
import { siteConfig } from '../../config/site';
import { serviceAreas } from '../../config/services';
import { withBase } from '../../utils/routing';
import { t, getDateLocale, type Lang } from '../../i18n/ui';

const lang: Lang = 'tr';
const posts = (await getCollection('posts'))
	.filter((post) => (post.data.lang ?? 'tr') === 'tr')
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const dateLocale = getDateLocale(lang);
---

<BaseLayout
	title={`${t(lang, 'blog.eyebrow')} | ${siteConfig.brand.name}`}
	description="Müvekkiller ve iş sahipleri için güncel hukuki içgörüler, rehberler ve eğitici makaleler. Boşanma, miras, şirketler hukuku ve daha fazlası hakkında bilgi alın."
	pathname="/blog"
	lang={lang}
>
	<Section title={t(lang, 'blog.eyebrow')} lead={t(lang, 'blog.lead')}>
		<div class="filters">
			<div class="filter-field">
				<Icon name="search" size={16} />
				<input id="blog-search" class="input" type="search" placeholder={t(lang, 'blog.searchPlaceholder')} aria-label="Search blog posts" />
			</div>
			<div class="filter-field">
				<Icon name="filter" size={16} />
				<select id="tag-filter" class="select" aria-label="Filter by tag">
					<option value="">{t(lang, 'blog.allTags')}</option>
					{allTags.map((tag) => <option value={tag}>{tag}</option>)}
				</select>
			</div>
		</div>

		<div class="service-index-links">
			{serviceAreas.map((area) => (
				<a class="service-tag-link" href={withBase(`/hizmetler/${area.slug}`)}>{area.title}</a>
			))}
		</div>

		<div class="blog-list" id="blog-list">
			{
				posts.map((post) => (
					<div
						data-post
						data-title={post.data.title.toLowerCase()}
						data-description={post.data.description.toLowerCase()}
						data-tags={post.data.tags.join('|').toLowerCase()}
					>
						<BlogCard
							title={post.data.title}
							description={post.data.description}
							dateText={post.data.date.toLocaleDateString(dateLocale, {
								year: 'numeric',
								month: 'short',
								day: 'numeric',
							})}
							author={post.data.author}
							tags={post.data.tags}
							href={withBase(`/blog/${post.id.replace(/^tr\//, '')}`)}
						/>
					</div>
				))
			}
		</div>

		<p class="pagination-note">{t(lang, 'blog.paginationNote')}</p>
	</Section>

	<script type="application/ld+json" set:html={JSON.stringify({
		'@context': 'https://schema.org',
		'@type': 'Blog',
		name: `${t(lang, 'blog.eyebrow')} | ${siteConfig.brand.name}`,
		description: 'Müvekkiller ve iş sahipleri için güncel hukuki içgörüler, rehberler ve eğitici makaleler.',
		url: `${siteConfig.seo.siteUrl}/blog`,
	})} />

	<style>
		.service-index-links {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			margin-bottom: 2rem;
		}

		.service-tag-link {
			font-size: 0.8rem;
			padding: 0.25rem 0.75rem;
			border: 1px solid var(--color-border);
			border-radius: var(--radius-sm);
			color: var(--color-text);
			text-decoration: none;
			transition: background 0.15s;
		}

		.service-tag-link:hover {
			background: var(--surface-bg);
		}

		@media (min-width: 640px) {
			.service-index-links {
				margin-bottom: 2.5rem;
			}
		}
	</style>

	<script>
		const searchEl = document.querySelector('#blog-search');
		const tagEl = document.querySelector('#tag-filter');
		const postEls = [...document.querySelectorAll('[data-post]')];

		const params = new URLSearchParams(window.location.search);
		const tagParam = params.get('tag');
		if (tagParam && tagEl) {
			tagEl.value = tagParam;
		}

		const applyFilter = () => {
			const searchValue = (searchEl?.value || '').toLowerCase().trim();
			const tagValue = (tagEl?.value || '').toLowerCase().trim();

			for (const item of postEls) {
				const title = item.getAttribute('data-title') || '';
				const description = item.getAttribute('data-description') || '';
				const tags = item.getAttribute('data-tags') || '';

				const matchesText =
					!searchValue || title.includes(searchValue) || description.includes(searchValue);
				const matchesTag = !tagValue || tags.includes(tagValue);

				item.style.display = matchesText && matchesTag ? 'block' : 'none';
			}
		};

		applyFilter();

		searchEl?.addEventListener('input', applyFilter);
		tagEl?.addEventListener('change', applyFilter);
	</script>
</BaseLayout>
