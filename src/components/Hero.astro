---
import { helpDeskTriggerAriaLabel, helpDeskTriggerHref } from '../config/site';

interface Props {
	eyebrow?: string;
	title: string;
	summary: string;
	primaryLabel: string;
	primaryHref: string;
	secondaryLabel?: string;
	secondaryHref?: string;
}

const {
	eyebrow = 'Law Office',
	title,
	summary,
	primaryLabel,
	primaryHref,
	secondaryLabel,
	secondaryHref,
} = Astro.props;

const primaryAriaLabel = primaryHref === helpDeskTriggerHref ? helpDeskTriggerAriaLabel : undefined;
const secondaryAriaLabel = secondaryHref === helpDeskTriggerHref ? helpDeskTriggerAriaLabel : undefined;
---

<section class="hero">
	<div>
		<p class="eyebrow">{eyebrow}</p>
		<h1>{title}</h1>
		<p>{summary}</p>
	</div>
	<div class="button-row">
		<a class="btn btn-primary" href={primaryHref} aria-label={primaryAriaLabel}>{primaryLabel}</a>
		{secondaryLabel && secondaryHref && <a class="btn btn-secondary" href={secondaryHref} aria-label={secondaryAriaLabel}>{secondaryLabel}</a>}
	</div>
</section>
