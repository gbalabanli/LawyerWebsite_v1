---
import { getAlternatePath, getAlternateLangs, type Lang } from '../i18n/utils';
import { withBase } from '../utils/routing';

interface Props {
	lang: Lang;
	pathname: string;
}

const { lang, pathname } = Astro.props;
const basePath = import.meta.env.BASE_URL || '/';
const pathnameWithoutBase =
	basePath !== '/' && pathname.startsWith(basePath)
		? pathname.slice(basePath.length) || '/'
		: pathname;

const altLang = getAlternateLangs(lang)[0];
const trHref = getAlternatePath(pathnameWithoutBase, 'tr');
const enHref = getAlternatePath(pathnameWithoutBase, 'en');
---

<nav class="lang-switcher" aria-label="Language">
	<span class="lang-switcher-item" data-active={lang === 'tr'}>
		{lang === 'tr' ? (
			<span>TR</span>
		) : (
			<a href={withBase(trHref)}>TR</a>
		)}
	</span>
	<span class="lang-divider" aria-hidden="true">|</span>
	<span class="lang-switcher-item" data-active={lang === 'en'}>
		{lang === 'en' ? (
			<span>EN</span>
		) : (
			<a href={withBase(enHref)}>EN</a>
		)}
	</span>
</nav>
